generator client {
  provider = "prisma-client-js"
  output   = "../generated/stats-client"
}

datasource db {
  provider = "postgresql"
  url      = env("STATS_DATABASE_URL")
}

model game {
  game_id     BigInt
  name        String
  box_art_url String
  updated_at  DateTime @db.Timestamptz(6)
  platform    String

  @@id([platform, game_id])
}

model probe {
  stream_id String
  user_id   BigInt
  viewers   Int
  time      DateTime @db.Timestamptz(6)
  platform  String

  @@id([platform, stream_id, user_id, time])
}

model stream {
  stream_id  String
  user_id    BigInt
  title      String
  tags       String[]
  game_id    BigInt
  started_at DateTime  @db.Timestamptz(6)
  ended_at   DateTime? @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
  platform   String

  @@id([platform, stream_id])
  @@index([ended_at])
  @@index([started_at])
  @@index([updated_at])
  @@index([platform, user_id], map: "stream_user_id_idx")
}

model stream_game {
  stream_id String
  game_id   BigInt
  time      DateTime @db.Timestamptz(6)
  platform  String

  @@id([platform, stream_id, game_id, time])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model stream_tags {
  stream_id String
  tag       String[]
  time      DateTime @db.Timestamptz(6)
  platform  String

  // prisma cannot represent an array column inside a primary key ("ID
  // definitions must reference only required fields"), so the real PK
  // (platform, stream_id, tag, time) stays commented out and the model is
  // ignored. Postgres remains the source of truth; see db/README.md.
  //@@id([platform, stream_id, tag, time])

  @@ignore
}

model stream_title {
  stream_id String
  title     String
  time      DateTime @db.Timestamptz(6)
  platform  String

  @@id([platform, stream_id, title, time])
}

model streamers {
  user_id          BigInt
  login            String
  display_name     String
  type             String
  profile_image    String
  view_count       BigInt    @default(0)
  follower         BigInt    @default(0)
  broadcaster_type String
  created_at       DateTime? @db.Timestamptz(6)
  vods_updated_at  DateTime? @db.Timestamptz(6)
  vods_forever     Boolean   @default(false)
  updated_at       DateTime? @db.Timestamptz(6)
  platform         String

  @@id([platform, user_id])
  @@index([platform, login], map: "streamers_login_idx")
  @@index([updated_at])
  @@index([vods_updated_at])
}

model streamers_follower_probe {
  user_id  BigInt
  follower BigInt
  time     DateTime @db.Timestamptz(6)
  platform String

  @@id([platform, user_id, time])
}

model streamers_views_probe {
  user_id    BigInt
  view_count BigInt
  time       DateTime @db.Timestamptz(6)
  platform   String

  @@id([platform, user_id, time])
}

model tags {
  tag_id                    String   @id @db.Uuid
  is_auto                   Boolean
  localization_names        String
  localization_descriptions String
  updated_at                DateTime @db.Timestamptz(6)
}

model user_online {
  user_id     BigInt
  stream_id   String
  last_update DateTime @db.Timestamptz(6)
  platform    String

  @@id([platform, stream_id, user_id])
  @@index([last_update])
}

model archive_stream {
  stream_id   String
  user_id     BigInt
  started_at  DateTime @db.Timestamptz(6)
  ended_at    DateTime @db.Timestamptz(6)
  object_key  String
  byte_offset BigInt
  byte_length Int
  platform    String

  @@id([platform, stream_id])
  @@index([user_id, started_at], map: "archive_stream_user_idx")
  @@index([platform, user_id, started_at], map: "archive_stream_user_started_idx")
}

model stream_summary {
  stream_id        String
  user_id          BigInt
  started_at       DateTime @db.Timestamptz(6)
  ended_at         DateTime @db.Timestamptz(6)
  duration_seconds Int
  avg_viewers      Float    @db.Real
  peak_viewers     Int
  probe_count      Int
  game_ids         BigInt[]
  title_count      Int
  platform         String

  @@id([platform, stream_id])
  @@index([started_at], map: "stream_summary_started_idx")
  @@index([user_id, started_at], map: "stream_summary_user_idx")
  @@index([platform, user_id, started_at], map: "stream_summary_user_started_idx")
}
